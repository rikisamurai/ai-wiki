filters:
  and:
    - file.inFolder("wiki")
    - file.ext == "md"
properties:
  last-ingested:
    displayName: 最近 ingest
  status:
    displayName: 状态
  tags:
    displayName: tags
views:
  - type: table
    name: ingest-timeline
    order:
      - file.name
      - last-ingested
      - status
      - tags
    sort:
      - property: last-ingested
        direction: DESC
    limit: 100
